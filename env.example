# 🔐 Configuration du système RAG - JurisBot CI
# Copier ce fichier en .env et remplir les valeurs

# ========================================
# OBLIGATOIRE - Mistral AI
# ========================================

# Clé API Mistral (obtenir sur https://console.mistral.ai/)
MISTRAL_API_KEY=your-mistral-api-key-here

# ========================================
# OPTIONNEL - Supabase pgvector (Production)
# ========================================

# URL de votre projet Supabase
# Format: https://xxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Clé API Supabase (anon key)
# Obtenir sur: https://app.supabase.com/project/[PROJECT]/settings/api
SUPABASE_KEY=your-supabase-anon-key-here

# ========================================
# OPTIONNEL - Configuration RAG
# ========================================

# Chemin vers le fichier principal de documents
DOCUMENTS_PATH=code_du_travail_ci.md

# Répertoire pour les index FAISS
FAISS_INDEX_DIR=./faiss_indexes

# Répertoire pour les logs d'ingestion
INGESTION_LOG_DIR=./ingestion_logs

# ========================================
# OPTIONNEL - Debug
# ========================================

# Niveau de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Afficher les logs détaillés
VERBOSE=false
